# topologia.env — Única fuente de verdad de la red distribuida DiscoPass.
#
# Lo consumen tanto run.sh (arranque por-máquina, foreground) como disco
# (orquestador SSH). Dos canales DISTINTOS conviven aquí:
#
#   1. SSH_*  → cómo la máquina de control alcanza cada máquina (ssh dist0NN).
#              Requiere entradas Host en ~/.ssh/config (ver README). NO usar
#              los alias ssh-0NN: no existen en shells no interactivos.
#   2. IP_*   → IP real con la que los PROCESOS gRPC se dialogan entre máquinas.
#              Se usan IPs (no FQDN) para una conexión más sólida e independiente
#              del DNS del laboratorio.

# --- Canal de control (SSH) ---
SSH_057=dist057
SSH_058=dist058
SSH_059=dist059
SSH_060=dist060

# --- Canal de datos (gRPC) : IPs de la red cerrada del lab ---
IP_057=10.35.168.67
IP_058=10.35.168.68
IP_059=10.35.168.69
IP_060=10.35.168.70

# --- Puertos (distintos por componente → conviven varios por máquina) ---
P_BROKER=50051
P_BANCO=50052
P_DB1=50061
P_DB2=50062
P_DB3=50063

# --- Directorio de despliegue remoto (en cada máquina) ---
REMOTE_DIR=discopass

# --- Direcciones derivadas (dial gRPC por IP) ---
# Mapeo: Broker@057 · DB3@058 · DB2@059 · Banco+DB1@060
BROKER_ADDR=$IP_057:$P_BROKER
NODOS=$IP_060:$P_DB1,$IP_059:$P_DB2,$IP_058:$P_DB3   # DB1@060, DB2@059, DB3@058
BANCO_ADDR=$IP_060:$P_BANCO
